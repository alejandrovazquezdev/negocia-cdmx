# NegociaCDMX — variables de entorno
# Copia este archivo a `.env` y rellena los valores reales.
# `.env` está en .gitignore y NUNCA debe commitearse.

# --- Chatbot: Google Gemini (o Vertex AI Express) ----------------------------
# Clave de API para el modelo Gemini. Se usa server-side únicamente.
# Obtén una en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Modelo a usar. Opciones comunes:
#   - "gemini-2.5-flash"  (estable, recomendado, default)
#   - "gemini-2.5-pro"    (mejor razonamiento, 1M contexto)
#   - "gemini-2.0-flash"  (puede estar deprecado el alias, usar -001/-lite/-pro)
GEMINI_MODEL=gemini-2.5-flash

# --- Base de datos ------------------------------------------------------------
# Ruta al archivo SQLite. Default: data/negocia.db (en la raíz del proyecto).
DATABASE_PATH=data/negocia.db
